/**app.wxss**/
page {
  background-color: #faf8ff;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
  color: #1e293b;
  font-size: 28rpx;
  box-sizing: border-box;
}

.container {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  min-height: 100vh;
}

.btn-primary {
  background: linear-gradient(135deg, #1650e0, #3d6bfa);
  color: #ffffff;
  font-weight: bold;
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(22, 80, 224, 0.2);
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  border: 1rpx solid #f1f5f9;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  margin-bottom: 30rpx;
}