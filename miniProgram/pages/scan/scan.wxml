<!--pages/scan/scan.wxml-->
<view class="scan-page">
  <camera device-position="back" flash="off" binderror="error" class="wechat-camera">
    <view class="focus-bracket">
      <view class="bracket-item tl"></view>
      <view class="bracket-item tr"></view>
      <view class="bracket-item bl"></view>
      <view class="bracket-item br"></view>
      <view class="scanning-beam" wx:if="{{isScanning}}"></view>
    </view>
  </camera>

  <view class="camera-dock">
    <view class="switch-scenarios-tip">切换模拟做题卡：</view>
    <scroll-view scroll-x class="sample-list" enable-flex>
      <view class="sample-item" bindtap="selectSample">三位数除法</view>
      <view class="sample-item" bindtap="selectSample">一元二次方程</view>
      <view class="sample-item" bindtap="selectSample">阿基米德浮力</view>
    </scroll-view>

    <view class="controls-row">
      <view class="btn-icon">📁 相册</view>
      <view class="shutter-outer" bindtap="startScan">
        <view class="shutter-inner"></view>
      </view>
      <view class="btn-icon">整页 📖</view>
    </view>
  </view>
</view>