/**index.wxss**/
page {
  height: 100%;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page-wrapper {
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
  box-sizing: border-box;
}

.app-layout {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  background: white;
}

.sidebar {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
}

.sidebar-title {
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.4;
  text-align: center;
}

.sidebar-controls {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  margin-top: 20rpx;
}

.ingest-button {
  width: 100%;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  border: none;
  border-radius: 25rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  line-height: normal;
}

.ingest-button::after {
  border: none;
}

.ingest-button[disabled] {
  opacity: 0.7;
}

.document-select {
  width: 100%;
  padding: 20rpx 30rpx;
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.3);
  color: white;
  border-radius: 15rpx;
  box-sizing: border-box;
  text-align: center;
}

.chat-container {
  flex: 1;
  background: white;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-height: 0;
}

.chat-messages {
  flex: 1;
  height: 0;
  padding: 20rpx;
  background: #f5f5f5;
  box-sizing: border-box;
}

.message {
  margin-bottom: 15rpx;
  display: flex;
}

.message.user {
  justify-content: flex-end;
}

.message.ai {
  justify-content: flex-start;
}

.message-content {
  max-width: 85%;
  padding: 16rpx 22rpx;
  border-radius: 18rpx;
  word-wrap: break-word;
  line-height: 1.8;
  font-size: 28rpx;
}

.message.user .message-content {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-bottom-right-radius: 4rpx;
}

.message.ai .message-content {
  background: white;
  color: #333;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 2rpx 5rpx rgba(0, 0, 0, 0.1);
}

.welcome-message {
  text-align: center;
  color: #999;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.welcome-title {
  font-size: 36rpx;
  margin-bottom: 12rpx;
  color: #667eea;
  font-weight: 600;
}

.welcome-desc {
  font-size: 28rpx;
}

.chat-input-container {
  padding: 20rpx;
  background: white;
  border-top: 1px solid #e0e0e0;
  display: flex;
  gap: 10rpx;
  flex-shrink: 0;
  align-items: center;
}

.chat-input {
  flex: 1;
  padding: 12rpx 18rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 25rpx;
  font-size: 28rpx;
  height: 72rpx;
  box-sizing: border-box;
}

.send-button {
  padding: 12rpx 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 25rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: normal;
  margin: 0;
}

.send-button::after {
  border: none;
}

.send-button[disabled] {
  opacity: 0.6;
}

.button-spinner {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading {
  display: inline-block;
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid #f3f3f3;
  border-top: 3rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
