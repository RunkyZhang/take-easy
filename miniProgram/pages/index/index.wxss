/* pages/index/index.wxss */
.welcome-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  margin-bottom: 40rpx;
}

.welcome-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 38rpx;
  font-weight: bold;
  color: #0f172a;
}

.sub-title {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 10rpx;
}

.user-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  border: 4rpx solid #e0e7ff;
}

.scan-banner {
  background: linear-gradient(135deg, #1650e0, #3d6bfa);
  border-radius: 32rpx;
  padding: 40rpx;
  color: #ffffff;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  margin-bottom: 40rpx;
}

.banner-badge {
  background-color: rgba(255, 255, 255, 0.2);
  align-self: flex-start;
  padding: 6rpx 18rpx;
  border-radius: 50rpx;
  margin-bottom: 20rpx;
}

.badge-text {
  font-size: 20rpx;
  font-weight: bold;
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.5;
  margin-bottom: 30rpx;
}

.scan-btn {
  background-color: #ffffff;
  color: #1650e0;
  border-radius: 50rpx;
  font-size: 26rpx;
  font-weight: bold;
  align-self: flex-start;
  padding: 12rpx 36rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #0f172a;
}

.section-link {
  font-size: 24rpx;
  color: #1650e0;
}

.goal-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #e2e8f0;
  margin-bottom: 20rpx;
}

.goal-icon-box {
  width: 80rpx;
  height: 80rpx;
  background-color: #f0f3ff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  margin-right: 20rpx;
}

.goal-info {
  flex: 1;
}

.goal-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.goal-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #334155;
}

.goal-progress-num {
  font-size: 22rpx;
  color: #64748b;
}

.progress-bar-bg {
  height: 10rpx;
  background-color: #f1f5f9;
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #10b981, #059669);
  border-radius: 10rpx;
  transition: width 0.3s ease;
}