<!--pages/index/index.wxml-->
<view class="container index-page">
  <!-- 欢迎栏 -->
  <view class="welcome-section">
    <view class="welcome-info">
      <text class="user-name">你好，子涵家长 👋</text>
      <text class="sub-title">今天又是充满进步的一天！</text>
    </view>
    <image class="user-avatar" src="{{profileAvatar}}" mode="aspectFill"></image>
  </view>

  <!-- 拍搜卡片 -->
  <view class="scan-banner" bindtap="goToScan">
    <view class="banner-content">
      <view class="banner-badge">
        <text class="badge-text">✨ AI 智能拍搜</text>
      </view>
      <text class="banner-title">AI 智能拍照搜题</text>
      <text class="banner-desc">秒级识别手写错题，提供多维度解析、知识点剖析</text>
    </view>
    <button class="scan-btn">
      <text>立即开始扫描</text>
    </button>
  </view>

  <!-- 今日学习目标 -->
  <view class="section-header">
    <text class="section-title">今日学习目标</text>
    <text class="section-link" bindtap="goToReport">查看报告 ></text>
  </view>
  
  <view class="goals-list">
    <block wx:for="{{goals}}" wx:key="id">
      <view class="goal-card" bindtap="onGoalClick" data-id="{{item.id}}">
        <view class="goal-icon-box">🧠</view>
        <view class="goal-info">
          <view class="goal-row">
            <text class="goal-title">{{item.title}}</text>
            <text class="goal-progress-num">{{item.currentMinutes}}/{{item.targetMinutes}} 分钟</text>
          </view>
          <view class="progress-bar-bg">
            <view class="progress-bar-fill" style="width: {{item.currentMinutes / item.targetMinutes * 100}}%"></view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 周历视图 -->
  <view class="section-header">
    <text class="section-title">本周进步</text>
  </view>
  
  <view class="card chart-card">
    <view class="chart-bar-container">
      <block wx:for="{{weeklyStats}}" wx:key="day">
        <view class="chart-col">
          <view class="bar-wrapper">
            <view class="chart-bar {{item.active ? 'active' : ''}}" style="height: {{item.value}}%"></view>
          </view>
          <text class="chart-label {{item.active ? 'active' : ''}}">{{item.day}}</text>
        </view>
      </block>
    </view>
    <view class="insight-box">
      <text class="insight-title font-bold text-[#10b981]">📈 本周学习效率提升 12%</text>
      <text class="insight-desc">子涵在数学几何方面的掌握度明显提高，继续加油！</text>
    </view>
  </view>
</view>