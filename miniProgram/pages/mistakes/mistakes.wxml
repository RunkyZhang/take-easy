<!--pages/mistakes/mistakes.wxml-->
<view class="container">
  <view class="header-box">
    <text class="main-title">我的错题本</text>
    <text class="sub-desc">温故而知新，吃透盲区点</text>
  </view>

  <view class="search-row">
    <input class="wechat-search-input" placeholder="输入关键字搜索错题..." />
  </view>

  <scroll-view scroll-x class="subject-scrollbar" enable-flex>
    <view class="subject-tab active">数学</view>
    <view class="subject-tab">语文</view>
    <view class="subject-tab">英语</view>
    <view class="subject-tab">科学</view>
  </scroll-view>

  <view class="mistakes-grid">
    <block wx:for="{{mistakes}}" wx:key="id">
      <view class="card mistake-list-card">
        <image class="mistake-thumb" src="{{item.image}}" mode="aspectFill"></image>
        <view class="mistake-info-box">
          <text class="m-title">{{item.title}}</text>
          <text class="m-tag">错误率: {{item.errorRate}}%</text>
          <view class="action-row">
            <button class="practice-mini-btn" bindtap="toPractice" data-id="{{item.id}}">专项巩固</button>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>