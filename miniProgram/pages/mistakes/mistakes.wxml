<!--pages/mistakes/mistakes.wxml-->
<view className="container">
  <view className="header-box">
    <text className="main-title">我的错题本</text>
    <text className="sub-desc">温故而知新，吃透盲区点</text>
  </view>

  <view className="search-row">
    <input className="wechat-search-input" placeholder="输入关键字搜索错题..." />
  </view>

  <scroll-view scroll-x className="subject-scrollbar" enable-flex>
    <view className="subject-tab active">数学</view>
    <view className="subject-tab">语文</view>
    <view className="subject-tab">英语</view>
    <view className="subject-tab">科学</view>
  </scroll-view>

  <view className="mistakes-grid">
    <block wx:for="{{mistakes}}" wx:key="id">
      <view className="card mistake-list-card">
        <image className="mistake-thumb" src="{{item.image}}" mode="aspectFill"></image>
        <view className="mistake-info-box">
          <text className="m-title">{{item.title}}</text>
          <text className="m-tag">错误率: {{item.errorRate}}%</text>
          <view className="action-row">
            <button className="practice-mini-btn" bindtap="toPractice" data-id="{{item.id}}">专项巩固</button>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>